<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Monate, Datum &amp; Ordnungszahlen (A1.1)</title>
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
body { font-family: 'Segoe UI', system-ui, -apple-system, sans-serif; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); min-height: 100vh; padding: 20px; }
.container { max-width: 900px; margin: 0 auto; background: white; border-radius: 16px; box-shadow: 0 20px 60px rgba(0,0,0,0.3); overflow: hidden; }
.header { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 30px; text-align: center; }
.header h1 { font-size: 2em; color: white; margin-bottom: 8px; border: none; padding: 0; }
.header .subtitle { font-size: 1.0em; opacity: 0.85; color: rgba(255,255,255,0.9); margin: 0; }
.content-area { padding: 28px 30px 30px 30px; }
.nav { display: flex; flex-wrap: wrap; background: #f8f9fa; border-bottom: 2px solid #e9ecef; }
.nav-btn { flex: 1 1 18%; padding: 15px 10px; text-align: center; cursor: pointer; border: none; background: transparent; font-size: 0.95em; font-weight: 500; color: #6c757d; transition: all 0.3s; white-space: nowrap; min-width: 120px; user-select: none; }
.nav-btn:hover { background: #e9ecef; color: #495057; }
.nav-btn.active { background: white; color: #667eea; border-bottom: 3px solid #667eea; font-weight: 600; }
.section { display: none; }
.section.active { display: block; }
h2 { color: #333; font-size: 1.15em; margin-bottom: 16px; padding-bottom: 8px; border-bottom: 2px solid #f0f0f0; }
.btn-row { display: flex; gap: 10px; margin-top: 20px; flex-wrap: wrap; justify-content: center; }
.btn { padding: 10px 22px; border: none; border-radius: 25px; font-weight: 600; font-size: 0.9em; cursor: pointer; transition: all 0.2s; }
.btn-show { background: #f0f0f0; color: #555; }
.btn-show:hover { background: #e0e0e0; }
.btn-reset { background: #fff; color: #e74c3c; border: 2px solid #e74c3c; }
.btn-reset:hover { background: #e74c3c; color: white; }
.timer-display { display: flex; justify-content: center; gap: 20px; margin-top: 14px; font-size: 0.95em; }
.current-time { font-weight: 600; color: #667eea; }
.best-time { font-weight: 600; color: #f39c12; }
.help-box { background: #f8f9ff; border-left: 4px solid #667eea; border-radius: 0 10px 10px 0; padding: 14px 18px; margin-bottom: 20px; font-size: 0.9em; line-height: 1.7; color: #444; }
.help-box strong { color: #667eea; }

/* Entdeckungs-Tab */
.entdeck-intro { background: #f3e5f5; border-radius: 12px; padding: 18px 22px; margin-bottom: 20px; border-left: 5px solid #9c27b0; font-size: 0.97rem; line-height: 1.75; }
.entdeck-intro h3 { color: #6a1b9a; margin-bottom: 10px; font-size: 1.05rem; }
.hl { background: #e1bee7; border-radius: 4px; padding: 0 4px; color: #4a148c; font-weight: 700; }
.mc-step { display: none; background: #fafbff; border-radius: 12px; padding: 18px 22px; margin-bottom: 16px; border: 1px solid #c5cae9; }
.mc-step.active { display: block; }
.mc-step h4 { color: #3949ab; margin-bottom: 12px; font-size: 0.97rem; }
.mc-options { display: flex; flex-direction: column; gap: 8px; }
.mc-btn { padding: 9px 16px; border: 2px solid #c5cae9; border-radius: 8px; background: #fff; cursor: pointer; text-align: left; font-size: 0.92rem; transition: all .2s; }
.mc-btn:hover { border-color: #667eea; background: #f3f4ff; }
.mc-btn.correct { border-color: #43a047; background: #e8f5e9; color: #2e7d32; font-weight: 700; }
.mc-btn.wrong { border-color: #e53935; background: #ffebee; color: #c62828; }
.mc-feedback { margin-top: 10px; font-size: 0.88rem; min-height: 1.3em; }
.mc-feedback.ok { color: #2e7d32; font-weight: 700; }
.mc-feedback.err { color: #c62828; }
.progress-dots { display: flex; gap: 8px; margin-bottom: 20px; }
.pdot { width: 14px; height: 14px; border-radius: 50%; background: #c5cae9; transition: background .3s; }
.pdot.done { background: #667eea; }
.regel-karte { display: none; background: linear-gradient(135deg, #e8eaf6, #ede7f6); border-radius: 14px; padding: 22px 26px; border-left: 5px solid #3949ab; margin-top: 10px; }
.regel-karte h3 { color: #1a237e; margin-bottom: 12px; font-size: 1.05rem; }
.regel-karte li { color: #333; line-height: 1.8; font-size: 0.95rem; }
.regel-karte ul { margin-left: 18px; }
.regel-karte .rk-example { background: #fff; border-radius: 8px; padding: 10px 14px; margin-top: 12px; border-left: 3px solid #7c4dff; font-size: 0.9rem; color: #333; }
.regel-karte .rk-example b { color: #3949ab; }
.rk-table { width: 100%; border-collapse: collapse; margin-top: 12px; font-size: 0.9rem; }
.rk-table th { background: #3949ab; color: white; padding: 8px 12px; text-align: left; }
.rk-table td { padding: 7px 12px; border-bottom: 1px solid #e0e0e0; }
.rk-table tr:nth-child(even) td { background: #f3f4ff; }

/* Lücken */
.ex-card { background: #f8f9ff; padding: 16px 20px; margin-bottom: 14px; border-radius: 10px; border-left: 4px solid #667eea; position: relative; }
.ex-badge { position: absolute; top: 10px; right: 14px; background: linear-gradient(135deg, #667eea, #764ba2); color: white; font-size: 0.7em; padding: 3px 10px; border-radius: 12px; font-weight: 600; }
.ex-sentence { font-size: 1.0em; line-height: 2.4; color: #333; display: block; }
.nowrap-group { display: inline-flex; align-items: baseline; white-space: nowrap; gap: 0; }
input.blank { border: none; border-bottom: 2px solid #667eea; background: #fff; padding: 4px 8px; font-family: inherit; font-size: 0.95em; outline: none; transition: all 0.2s; }
input.blank:focus { border-bottom-color: #764ba2; background: #f0f7ff; }
input.blank.s { min-width: 50px; width: 50px; }
input.blank.m { min-width: 90px; width: 90px; }
input.blank.l { min-width: 150px; width: 150px; }
input.blank.xl { min-width: 200px; width: 200px; }
input.blank.xxl { min-width: 280px; width: 280px; }
input.blank.correct { border-bottom-color: #27ae60; background: #e8f8f0; }
input.blank.wrong { border-bottom-color: #e74c3c; background: #fdeaea; }
.correction-hint { color: #27ae60; font-weight: 600; font-size: 0.85em; margin-left: 4px; white-space: nowrap; }

/* Chips & Zuordnung */
.drop-zone-container { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; margin-bottom: 20px; }
.drop-zone { background: #f0f0f0; border: 2px dashed #ccc; border-radius: 10px; padding: 12px; min-height: 110px; transition: border-color 0.2s; }
.drop-zone:hover { border-color: #667eea; }
.drop-zone-title { font-weight: 700; color: #667eea; text-align: center; margin-bottom: 8px; font-size: 0.9em; }
.chip-bank { display: flex; flex-wrap: wrap; gap: 8px; padding: 14px; background: #f8f8f8; border-radius: 10px; min-height: 60px; }
.chip { background: white; border: 2px solid #667eea; color: #667eea; padding: 8px 14px; border-radius: 20px; cursor: move; font-weight: 500; font-size: 0.9em; transition: all 0.2s; user-select: none; display: inline-block; margin: 2px; }
.chip:hover { transform: scale(1.05); box-shadow: 0 4px 12px rgba(102,126,234,0.3); }
.chip.correct { background: #27ae60; border-color: #27ae60; color: white; }
.chip.wrong { background: #e74c3c; border-color: #e74c3c; color: white; }
.chip.selected { outline: 3px solid #f39c12; }

/* Satzbau */
.satzbau-item { background: #f8f9ff; padding: 16px 20px; margin-bottom: 20px; border-radius: 10px; border-left: 4px solid #667eea; }
.sb-label { font-size: 0.8em; color: #888; margin-bottom: 6px; font-weight: 600; }
.drop-row { background: white; border: 2px dashed #ccc; border-radius: 10px; padding: 14px; min-height: 60px; margin-bottom: 12px; display: flex; flex-wrap: wrap; gap: 6px; align-items: center; }
.drop-row .chip { margin: 0; }
.chip.punct { min-width: 32px; padding: 8px 10px; font-size: 1.2em; font-weight: 700; text-align: center; }
.drop-row .chip.punct { margin-left: -4px; }
.fixed-dot { font-size: 1.5em; margin-left: 4px; }

/* Wortschatz */
.vocab-item { background: #f8f9ff; padding: 14px 18px; margin-bottom: 12px; border-radius: 10px; border-left: 4px solid #667eea; display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
.vocab-en { font-weight: 600; color: #764ba2; min-width: 160px; font-size: 0.95em; }
.vocab-arrow { color: #ccc; font-size: 1.2em; }
.vocab-inputs { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }
.vocab-inputs input { border: none; border-bottom: 2px solid #667eea; background: #fff; padding: 4px 8px; font-family: inherit; font-size: 0.95em; outline: none; transition: all 0.2s; }
.vocab-inputs input:focus { border-bottom-color: #764ba2; background: #f0f7ff; }
.vocab-inputs input.correct { border-bottom-color: #27ae60; background: #e8f8f0; }
.vocab-inputs input.wrong { border-bottom-color: #e74c3c; background: #fdeaea; }
.vocab-inputs input.art { width: 50px; }
.vocab-inputs input.wort { width: 130px; }
.vocab-inputs input.plural { width: 140px; }
.vocab-hint { color: #27ae60; font-weight: 600; font-size: 0.8em; margin-left: 6px; }

@media (max-width: 600px) {
      .drop-zone-container { grid-template-columns: repeat(2, 1fr); }
    .nav-btn { font-size: 0.78em; padding: 8px 12px; }
    .vocab-item { flex-direction: column; align-items: flex-start; }
}
.author-footer { margin-top: 40px; padding: 16px 20px; text-align: center; font-size: 0.8em; color: #888; border-top: 1px solid #e0e0e0; }
.author-footer a { color: #667eea; text-decoration: none; font-weight: 500; }
.author-footer a:hover { text-decoration: underline; color: #764ba2; }
.author-footer .author-name { font-weight: 600; color: #555; }
</style>
</head>
<body>
<div class="container">
    <div class="header">
        <h1>Monate, Datum &amp; Ordnungszahlen</h1>
        <div class="subtitle">Grammatik &middot; Monate &middot; Ordnungszahlen &middot; Datum &middot; DE_A1_1073G</div>
    </div>
    <div class="nav">
        <div class="nav-btn active" onclick="showSection(0)">&#128214; Entdecken</div>
        <div class="nav-btn" onclick="showSection(1)">&#127800; Monate &amp; Jahreszeiten</div>
        <div class="nav-btn" onclick="showSection(2)">&#128290; Ordnungszahlen</div>
        <div class="nav-btn" onclick="showSection(3)">&#128198; Datum schreiben</div>
        <div class="nav-btn" onclick="showSection(4)">&#128197; am + Datum</div>
        <div class="nav-btn" onclick="showSection(5)">&#129513; Satzbau</div>
        <div class="nav-btn" onclick="showSection(6)">&#128218; Wortschatz</div>
    </div>
    <div class="content-area">

    <!-- ===== TAB 0: ENTDECKEN ===== -->
    <div class="section active" id="sec-0">
        <h2>&#128214; Die Regel entdecken</h2>
        <div class="entdeck-intro">
            <h3>&#128270; Schau genau hin! Was f&auml;llt dir auf?</h3>
            <p>Heute ist <span class="hl">der erste</span> Januar.<br>
            Mein Geburtstag ist <span class="hl">am dreizehnten</span> Januar.<br>
            Weihnachten ist <span class="hl">am vierundzwanzigsten</span> Dezember.<br>
            Der 06.12. = <span class="hl">der sechste</span> Dezember.<br>
            Am <span class="hl">dritten</span> Oktober ist Tag der Deutschen Einheit.<br>
            Der 31.10. = <span class="hl">der einunddrei&szlig;igste</span> Oktober.</p>
        </div>

        <div class="progress-dots">
            <div class="pdot" id="pdot0"></div>
            <div class="pdot" id="pdot1"></div>
            <div class="pdot" id="pdot2"></div>
            <div class="pdot" id="pdot3"></div>
        </div>

        <!-- Schritt 1 -->
        <div class="mc-step active" id="mc-step0">
            <h4>Schritt 1: Was kommt bei Zahlen 2–19 ans Ende (Ordnungszahl)?</h4>
            <div class="mc-options">
                <button class="mc-btn" onclick="mcCheck(0, this, false)">-ste</button>
                <button class="mc-btn" onclick="mcCheck(0, this, true)">-te</button>
                <button class="mc-btn" onclick="mcCheck(0, this, false)">-en</button>
                <button class="mc-btn" onclick="mcCheck(0, this, false)">-e</button>
            </div>
            <div class="mc-feedback" id="mcfb0"></div>
        </div>

        <!-- Schritt 2 -->
        <div class="mc-step" id="mc-step1">
            <h4>Schritt 2: Was kommt ab Zahl 20 ans Ende?</h4>
            <div class="mc-options">
                <button class="mc-btn" onclick="mcCheck(1, this, false)">-te</button>
                <button class="mc-btn" onclick="mcCheck(1, this, true)">-ste</button>
                <button class="mc-btn" onclick="mcCheck(1, this, false)">-en</button>
                <button class="mc-btn" onclick="mcCheck(1, this, false)">-ten</button>
            </div>
            <div class="mc-feedback" id="mcfb1"></div>
        </div>

        <!-- Schritt 3 -->
        <div class="mc-step" id="mc-step2">
            <h4>Schritt 3: Nach <em>der</em> (Nominativ) hei&szlig;t es &bdquo;der <em>sechste</em>&ldquo;. Was kommt nach <em>am</em> (Dativ)?</h4>
            <div class="mc-options">
                <button class="mc-btn" onclick="mcCheck(2, this, false)">am sechste Dezember</button>
                <button class="mc-btn" onclick="mcCheck(2, this, true)">am sechsten Dezember</button>
                <button class="mc-btn" onclick="mcCheck(2, this, false)">am sechster Dezember</button>
                <button class="mc-btn" onclick="mcCheck(2, this, false)">am sechstem Dezember</button>
            </div>
            <div class="mc-feedback" id="mcfb2"></div>
        </div>

        <!-- Schritt 4 -->
        <div class="mc-step" id="mc-step3">
            <h4>Schritt 4: Welche Ordnungszahlen sind unregelm&auml;&szlig;ig (Ausnahmen)?</h4>
            <div class="mc-options">
                <button class="mc-btn" onclick="mcCheck(3, this, false)">1., 2., 5., 10.</button>
                <button class="mc-btn" onclick="mcCheck(3, this, true)">1. (erste), 3. (dritte), 7. (siebte), 8. (achte)</button>
                <button class="mc-btn" onclick="mcCheck(3, this, false)">1., 4., 6., 9.</button>
                <button class="mc-btn" onclick="mcCheck(3, this, false)">Es gibt keine Ausnahmen.</button>
            </div>
            <div class="mc-feedback" id="mcfb3"></div>
        </div>

        <!-- Regelkarte -->
        <div class="regel-karte" id="regelkarte">
            <h3>&#128218; Die Regel: Ordnungszahlen &amp; Datum</h3>
            <table class="rk-table">
                <tr><th>Endung</th><th>Wann</th><th>Beispiel</th></tr>
                <tr><td><b>-te</b></td><td>Zahlen 2–19 (Regelform)</td><td>der zweite, der sechste</td></tr>
                <tr><td><b>-ste</b></td><td>Zahlen ab 20</td><td>der zwanzigste, der einunddrei&szlig;igste</td></tr>
                <tr><td colspan="2"><b>Ausnahmen</b></td><td>der <b>erst</b>e (1.), <b>dritt</b>e (3.), <b>siebt</b>e (7.), <b>acht</b>e (8.)</td></tr>
            </table>
            <div class="rk-example">
                <b>der</b> (Nominativ): der sechste Dezember<br>
                <b>am</b> (Dativ): am sechsten Dezember &rarr; Endung: <b>-ten / -sten</b>
            </div>
        </div>
    </div>

    <!-- ===== TAB 1: MONATE ZUORDNUNG ===== -->
    <div class="section" id="sec-1">
        <h2>&#127800; Monate &amp; Jahreszeiten</h2>
        <div class="help-box">
            <strong>Aufgabe:</strong> Ordne die Monate der richtigen Jahreszeit zu!<br>
            &#128313; Fr&uuml;hling: M&auml;rz&ndash;Mai &middot; Sommer: Juni&ndash;August<br>
            &#128313; Herbst: September&ndash;November &middot; Winter: Dezember&ndash;Februar
        </div>
        <div class="drop-zone-container">
            <div class="drop-zone" data-cat="fr" id="zone-fr" ondragover="allowDrop(event)" ondrop="dropMon(event, this)">
                <div class="drop-zone-title">&#127800; Fr&uuml;hling</div>
            </div>
            <div class="drop-zone" data-cat="so" id="zone-so" ondragover="allowDrop(event)" ondrop="dropMon(event, this)">
                <div class="drop-zone-title">&#9728;&#65039; Sommer</div>
            </div>
            <div class="drop-zone" data-cat="he" id="zone-he" ondragover="allowDrop(event)" ondrop="dropMon(event, this)">
                <div class="drop-zone-title">&#127810; Herbst</div>
            </div>
            <div class="drop-zone" data-cat="wi" id="zone-wi" ondragover="allowDrop(event)" ondrop="dropMon(event, this)">
                <div class="drop-zone-title">&#10052;&#65039; Winter</div>
            </div>
        </div>
        <div class="chip-bank" id="monBank" ondragover="allowDrop(event)" ondrop="dropMonBank(event, this)"></div>
        <div class="btn-row">
            <button class="btn btn-show" onclick="showMonLoesung()">L&ouml;sungen</button>
            <button class="btn btn-reset" onclick="resetMon(); timerResetOne(1);">Neu starten</button>
        </div>
        <div class="timer-display">
            <span class="current-time">&#9201; <span id="timer-1">00:00</span></span>
            <span class="best-time">&#127942; Best: <span id="best-1">--:--</span></span>
        </div>
    </div>

    <!-- ===== TAB 2: ORDNUNGSZAHLEN ===== -->
    <div class="section" id="sec-2">
        <h2>&#128290; Ordnungszahlen</h2>
        <div class="help-box">
            <strong>Regel:</strong> Zahl + <strong>-te</strong> (1&ndash;19) oder Zahl + <strong>-ste</strong> (ab 20)<br>
            &#128313; <strong>Ausnahmen:</strong> der <strong>erste</strong> (1.), der <strong>dritte</strong> (3.), der <strong>siebte</strong> (7.), der <strong>achte</strong> (8.)
        </div>
        <div id="ordContainer"></div>
        <div class="btn-row">
            <button class="btn btn-show" onclick="showOrdLoesung()">L&ouml;sungen</button>
            <button class="btn btn-reset" onclick="resetOrd(); timerResetOne(2);">Neu starten</button>
        </div>
        <div class="timer-display">
            <span class="current-time">&#9201; <span id="timer-2">00:00</span></span>
            <span class="best-time">&#127942; Best: <span id="best-2">--:--</span></span>
        </div>
    </div>

    <!-- ===== TAB 3: DATUM SCHREIBEN ===== -->
    <div class="section" id="sec-3">
        <h2>&#128198; Datum schreiben</h2>
        <div class="help-box">
            <strong>Aufgabe:</strong> Schreibe das Datum in W&ouml;rtern!<br>
            &#128313; der 06.12. = der <strong>sechste Dezember</strong><br>
            &#128313; Nach <em>der</em>: Ordnungszahl + <strong>-te</strong> / <strong>-ste</strong>
        </div>
        <div id="datumContainer"></div>
        <div class="btn-row">
            <button class="btn btn-show" onclick="showDatumLoesung()">L&ouml;sungen</button>
            <button class="btn btn-reset" onclick="resetDatum(); timerResetOne(3);">Neu starten</button>
        </div>
        <div class="timer-display">
            <span class="current-time">&#9201; <span id="timer-3">00:00</span></span>
            <span class="best-time">&#127942; Best: <span id="best-3">--:--</span></span>
        </div>
    </div>

    <!-- ===== TAB 4: AM + DATUM ===== -->
    <div class="section" id="sec-4">
        <h2>&#128197; am + Datum</h2>
        <div class="help-box">
            <strong>Aufgabe:</strong> Erg&auml;nze das Datum nach <strong>am</strong>!<br>
            &#128313; Nach <em>am</em>: Ordnungszahl + <strong>-ten</strong> / <strong>-sten</strong><br>
            &#128313; am ersten, am dritten, am siebten, am achten
        </div>
        <div id="amDatContainer"></div>
        <div class="btn-row">
            <button class="btn btn-show" onclick="showAmDatLoesung()">L&ouml;sungen</button>
            <button class="btn btn-reset" onclick="resetAmDat(); timerResetOne(4);">Neu starten</button>
        </div>
        <div class="timer-display">
            <span class="current-time">&#9201; <span id="timer-4">00:00</span></span>
            <span class="best-time">&#127942; Best: <span id="best-4">--:--</span></span>
        </div>
    </div>

    <!-- ===== TAB 5: SATZBAU ===== -->
    <div class="section" id="sec-5">
        <h2>&#129513; Satzbau</h2>
        <div class="help-box">
            <strong>Tipp:</strong> Bringe die Satzteile in die richtige Reihenfolge!<br>
            &#128313; Das Verb steht immer auf Position 2.
        </div>
        <div id="satzbauContainer"></div>
        <div class="btn-row">
            <button class="btn btn-show" onclick="showSatzbauLoesung()">L&ouml;sungen</button>
            <button class="btn btn-reset" onclick="resetSatzbau(); timerResetOne(5);">Neu starten</button>
        </div>
        <div class="timer-display">
            <span class="current-time">&#9201; <span id="timer-5">00:00</span></span>
            <span class="best-time">&#127942; Best: <span id="best-5">--:--</span></span>
        </div>
    </div>

    <!-- ===== TAB 6: WORTSCHATZ ===== -->
    <div class="section" id="sec-6">
        <h2>&#128218; Wortschatz</h2>
        <div class="help-box">
            <strong>Aufgabe:</strong> &Uuml;bersetze die W&ouml;rter ins Deutsche. Bei Nomen: Artikel + Wort + Plural!
        </div>
        <div id="vocabContainer"></div>
        <div class="btn-row">
            <button class="btn btn-show" onclick="showVocabLoesung()">L&ouml;sungen</button>
            <button class="btn btn-reset" onclick="resetVocab(); timerResetOne(6);">Neu starten</button>
        </div>
        <div class="timer-display">
            <span class="current-time">&#9201; <span id="timer-6">00:00</span></span>
            <span class="best-time">&#127942; Best: <span id="best-6">--:--</span></span>
        </div>
    </div>

</div>

</div><!-- /content-area -->

<div class="author-footer">
    <span class="author-name">&copy; Frank Burkert</span> &middot; DaF-Materialien &middot;
    <a href="mailto:FrankBurkert@fabdaf.onmicrosoft.com">FrankBurkert@fabdaf.onmicrosoft.com</a>
</div>

<script>
/* ========== DATEN ========== */

