    { id:4, segments:[ {t:"4. = der "},{b:"vierte",s:"m"} ]},
    { id:5, segments:[ {t:"7. = der "},{b:"siebte",s:"m"} ]},
    { id:6, segments:[ {t:"8. = der "},{b:"achte",s:"m"} ]},
    { id:7, segments:[ {t:"12. = der "},{b:"zw\u00f6lfte",s:"m"} ]},
    { id:8, segments:[ {t:"15. = der "},{b:"f\u00fcnfzehnte",s:"l"} ]},
    { id:9, segments:[ {t:"20. = der "},{b:"zwanzigste",s:"l"} ]},
    { id:10, segments:[ {t:"31. = der "},{b:"einunddrei\u00dfigste",s:"xl"} ]}
];

var DATUM_LUECKEN = [
    { id:1, segments:[ {t:"der 06.12. = der "},{b:"sechste Dezember",s:"xl"} ]},
    { id:2, segments:[ {t:"der 24.12. = der "},{b:"vierundzwanzigste Dezember",s:"xxl"} ]},
    { id:3, segments:[ {t:"der 31.10. = der "},{b:"einunddrei\u00dfigste Oktober",s:"xxl"} ]},
    { id:4, segments:[ {t:"der 01.05. = der "},{b:"erste Mai",s:"l"} ]},
    { id:5, segments:[ {t:"der 31.12. = der "},{b:"einunddrei\u00dfigste Dezember",s:"xxl"} ]},
    { id:6, segments:[ {t:"der 06.01. = der "},{b:"sechste Januar",s:"xl"} ]},
    { id:7, segments:[ {t:"der 03.10. = der "},{b:"dritte Oktober",s:"xl"} ]},
    { id:8, segments:[ {t:"der 14.02. = der "},{b:"vierzehnte Februar",s:"xl"} ]},
    { id:9, segments:[ {t:"der 01.01. = der "},{b:"erste Januar",s:"xl"} ]},
    { id:10, segments:[ {t:"der 08.03. = der "},{b:"achte M\u00e4rz",s:"l"} ]}
];

var AMDAT_LUECKEN = [
    { id:1, segments:[ {t:"Ich habe am "},{b:"dreizehnten",s:"l"},{t:" Januar Geburtstag."} ]},
    { id:2, segments:[ {t:"Am "},{b:"ersten",s:"m"},{t:" Mai haben wir frei."} ]},
    { id:3, segments:[ {t:"Am "},{b:"dritten",s:"m"},{t:" Oktober ist Tag der Deutschen Einheit."} ]},
    { id:4, segments:[ {t:"Weihnachten ist am "},{b:"vierundzwanzigsten",s:"xl"},{t:" Dezember."} ]},
    { id:5, segments:[ {t:"Am "},{b:"siebten",s:"m"},{t:" August f\u00e4hrt sie nach Berlin."} ]},
    { id:6, segments:[ {t:"Der Frauentag ist am "},{b:"achten",s:"m"},{t:" M\u00e4rz."} ]},
    { id:7, segments:[ {t:"Silvester ist am "},{b:"einunddrei\u00dfigsten",s:"xl"},{t:" Dezember."} ]},
    { id:8, segments:[ {t:"Valentinstag ist am "},{b:"vierzehnten",s:"l"},{t:" Februar."} ]}
];

var SATZBAU = [
    { id:1, parts:["heute","ist","der erste Januar"], valid:[
        ["heute","ist","der erste Januar"]
    ]},
    { id:2, parts:["wann","hast","du","Geburtstag"], valid:[
        ["wann","hast","du","Geburtstag"]
    ], punct:"?"},
    { id:3, parts:["am dritten Oktober","ist","Tag der Deutschen Einheit"], valid:[
        ["am dritten Oktober","ist","Tag der Deutschen Einheit"]
    ]},
    { id:4, parts:["mein Geburtstag","ist","am f\u00fcnfzehnten Mai"], valid:[
        ["mein Geburtstag","ist","am f\u00fcnfzehnten Mai"]
    ]},
    { id:5, parts:["welches Datum","haben","wir","heute"], valid:[
        ["welches Datum","haben","wir","heute"]
    ], punct:"?"},
    { id:6, parts:["im Sommer","fahren","wir","nach Spanien"], valid:[
        ["im Sommer","fahren","wir","nach Spanien"],
        ["wir","fahren","im Sommer","nach Spanien"]
    ]},
    { id:7, parts:["Weihnachten","ist","am vierundzwanzigsten Dezember"], valid:[
        ["Weihnachten","ist","am vierundzwanzigsten Dezember"]
    ]},
    { id:8, parts:["im Winter","ist","es","kalt"], valid:[
        ["im Winter","ist","es","kalt"],
        ["es","ist","im Winter","kalt"]
    ]}
];

var WORTSCHATZ = [
    { id:1, type:"n", en:"\ud83d\udcc5 January", artikel:"der", de:"Januar", plural:"Januare" },
    { id:2, type:"n", en:"\ud83d\udcc5 February", artikel:"der", de:"Februar", plural:"Februare" },
    { id:3, type:"n", en:"\ud83c\udf38 March", artikel:"der", de:"M\u00e4rz", plural:"M\u00e4rze" },
    { id:4, type:"n", en:"\u2600\ufe0f June", artikel:"der", de:"Juni", plural:"Junis" },
    { id:5, type:"n", en:"\ud83c\udf42 October", artikel:"der", de:"Oktober", plural:"Oktober" },
    { id:6, type:"n", en:"\u2744\ufe0f December", artikel:"der", de:"Dezember", plural:"Dezember" },
    { id:7, type:"n", en:"\ud83c\udf82 birthday", artikel:"der", de:"Geburtstag", plural:"Geburtstage" },
    { id:8, type:"n", en:"\ud83d\udcc6 date", artikel:"das", de:"Datum", plural:"Daten" },
    { id:9, type:"n", en:"\ud83c\udf1e summer", artikel:"der", de:"Sommer", plural:"Sommer" },
    { id:10, type:"n", en:"\u2744\ufe0f winter", artikel:"der", de:"Winter", plural:"Winter" },
    { id:11, type:"n", en:"\ud83c\udf84 Christmas", artikel:"das", de:"Weihnachten", plural:"Weihnachten" },
    { id:12, type:"n", en:"\ud83c\udf86 New Year's Eve", artikel:"das", de:"Silvester", plural:"Silvester" },
    { id:13, type:"n", en:"\ud83c\udf89 party", artikel:"die", de:"Party", plural:"Partys" },
    { id:14, type:"a", en:"1\ufe0f\u20e3 first", de:"erste" },
    { id:15, type:"a", en:"3\ufe0f\u20e3 third", de:"dritte" },
    { id:16, type:"a", en:"7\ufe0f\u20e3 seventh", de:"siebte" }
];

/* ========== TAB NAVIGATION ========== */

function showSection(idx) {
    document.querySelectorAll('.section').forEach(function(s, i) { s.classList.toggle('active', i === idx); });
    document.querySelectorAll('.nav-btn').forEach(function(b, i) { b.classList.toggle('active', i === idx); });
}

/* ========== TIMER (Auto-Start / Auto-Stop) ========== */

var TIMER_PREFIX = 'a1-1073g-monate-datum-ord-';
var timerStarted  = [false, false, false, false, false, false, false];
var timerRunning  = [false, false, false, false, false, false, false];
var timerSeconds  = [0, 0, 0, 0, 0, 0, 0];
var timerIntervals = [null, null, null, null, null, null, null];

function timerAutoStart(n) {
    if (timerStarted[n]) return;
    timerStarted[n] = true;
    timerRunning[n] = true;
    timerIntervals[n] = setInterval(function() {
        timerSeconds[n]++;
        var el = document.getElementById('timer-' + n);
        if (el) el.textContent = timerFmt(timerSeconds[n]);
    }, 1000);
}

function timerStop(n) {
    if (!timerRunning[n]) return;
    clearInterval(timerIntervals[n]);
    timerRunning[n] = false;
    var key = TIMER_PREFIX + n;
    var prev = localStorage.getItem(key);
    if (!prev || timerSeconds[n] < parseInt(prev)) {
        localStorage.setItem(key, timerSeconds[n]);
        var best = document.getElementById('best-' + n);
        if (best) best.textContent = timerFmt(timerSeconds[n]);
    }
}

function timerResetOne(n) {
    clearInterval(timerIntervals[n]);
    timerStarted[n] = false;
    timerRunning[n] = false;
    timerSeconds[n] = 0;
    var el = document.getElementById('timer-' + n);
    if (el) el.textContent = '00:00';
}

function timerFmt(sec) {
    return String(Math.floor(sec / 60)).padStart(2, '0') + ':' + String(sec % 60).padStart(2, '0');
}

function loadBestTimes() {
    for (var i = 1; i <= 6; i++) {
        var val = localStorage.getItem(TIMER_PREFIX + i);
        var el = document.getElementById('best-' + i);
        if (val && el) el.textContent = timerFmt(parseInt(val));
    }
}

/* ========== MC-SYSTEM ========== */

var mcDone = [false, false, false, false];

function mcCheck(step, btn, correct) {
    var btns = btn.parentElement.querySelectorAll('.mc-btn');
    btns.forEach(function(b) { b.disabled = true; b.classList.remove('correct', 'wrong'); });
    var fb = document.getElementById('mcfb' + step);
    if (correct) {
        btn.classList.add('correct');
        fb.textContent = '\u2713 Richtig! Weiter zum n\u00e4chsten Schritt.';
        fb.className = 'mc-feedback ok';
        mcDone[step] = true;
        document.getElementById('pdot' + step).classList.add('done');
        setTimeout(function() {
            var next = document.getElementById('mc-step' + (step + 1));
            if (next) { next.classList.add('active'); }
            else { document.getElementById('regelkarte').style.display = 'block'; }
        }, 700);
    } else {
        btn.classList.add('wrong');
        fb.textContent = '\u2717 Nicht ganz \u2014 schau nochmal genau hin und versuche es erneut.';
        fb.className = 'mc-feedback err';
        setTimeout(function() {
            btns.forEach(function(b) { b.disabled = false; b.classList.remove('wrong', 'correct'); });
            fb.textContent = '';
            fb.className = 'mc-feedback';
        }, 1400);
    }
}

/* ========== LIVE CHECK ========== */

function liveCheck(inp) {
    var val = inp.value.trim().toLowerCase();
    var ans = (inp.dataset.answer || '').toLowerCase();
    inp.classList.remove('correct', 'wrong');
    if (val.length === 0) return;
    if (val === ans) { inp.classList.add('correct'); }
    else if (ans.indexOf(val) === 0) { /* prefix ok */ }
    else { inp.classList.add('wrong'); }
}

function checkAllInputs(selector, n) {
    var inputs = document.querySelectorAll(selector);
    if (inputs.length === 0) return;
    var allOk = true;
    inputs.forEach(function(inp) { if (!inp.classList.contains('correct')) allOk = false; });
    if (allOk) timerStop(n);
}

/* ========== DRAG & DROP (neue Architektur) ========== */

var draggedChip = null;

function allowDrop(e) { e.preventDefault(); }

function dropMon(e, zone) {
    e.preventDefault();
    if (!draggedChip) return;
    zone.appendChild(draggedChip);
    draggedChip.classList.remove('selected');
    colorAllMonChips();
    timerAutoStart(1);
    checkMonAllOk();
    draggedChip = null;
}

function dropMonBank(e, bank) {
    e.preventDefault();
    if (!draggedChip) return;
    bank.appendChild(draggedChip);
    draggedChip.classList.remove('selected', 'correct', 'wrong');
    draggedChip = null;
    colorAllMonChips();
}

function colorMonChip(chip) {
    var zone = chip.closest('.drop-zone');
    if (zone) {
        chip.classList.remove('correct', 'wrong');
        chip.classList.add(chip.dataset.cat === zone.dataset.cat ? 'correct' : 'wrong');
    } else {
        chip.classList.remove('correct', 'wrong');
    }
}

function colorAllMonChips() {
    document.querySelectorAll('#sec-1 .chip').forEach(function(chip) { colorMonChip(chip); });
}

function checkMonAllOk() {
    var chips = document.querySelectorAll('#sec-1 .chip');
    if (chips.length === 0) return;
    var allOk = true;
    chips.forEach(function(c) { if (!c.classList.contains('correct')) allOk = false; });
    if (allOk) timerStop(1);
}

var selectedMonChip = null;

function initMon() {
    var bank = document.getElementById('monBank');
    bank.innerHTML = '';
    ['fr','so','he','wi'].forEach(function(cat) {
        var zone = document.getElementById('zone-' + cat);
        var title = zone.querySelector('.drop-zone-title').outerHTML;
        zone.innerHTML = title;
    });
    var shuffled = MON_DATA.slice().sort(function() { return Math.random() - 0.5; });
    shuffled.forEach(function(item, idx) {
        var chip = document.createElement('div');
        chip.className = 'chip'; chip.textContent = item.word; chip.draggable = true;
        chip.dataset.cat = item.cat; chip.id = 'mon-chip-' + idx;
        chip.addEventListener('dragstart', function() {
            draggedChip = chip;
        });
        chip.addEventListener('dragend', function() {
            colorAllMonChips();
        });
        chip.addEventListener('click', function() {
            timerAutoStart(1);
            if (selectedMonChip === chip) { chip.classList.remove('selected'); selectedMonChip = null; return; }
            if (selectedMonChip) selectedMonChip.classList.remove('selected');
            selectedMonChip = chip; chip.classList.add('selected');
        });
        bank.appendChild(chip);
    });
    ['fr','so','he','wi'].forEach(function(cat) {
        var zone = document.getElementById('zone-' + cat);
        zone.addEventListener('click', function() {
            if (selectedMonChip) {
                zone.appendChild(selectedMonChip);
                selectedMonChip.classList.remove('selected'); selectedMonChip = null;
                colorAllMonChips(); timerAutoStart(1); checkMonAllOk();
            }
        });
    });
    bank.addEventListener('click', function() {
        if (selectedMonChip && !selectedMonChip.parentElement.classList.contains('chip-bank')) {
            bank.appendChild(selectedMonChip);
            selectedMonChip.classList.remove('selected', 'correct', 'wrong'); selectedMonChip = null;
            colorAllMonChips();
        }
    });
}

function showMonLoesung() {
    MON_DATA.forEach(function(item, idx) {
        var chip = document.getElementById('mon-chip-' + idx);
        var zone = document.getElementById('zone-' + item.cat);
        if (chip && zone) { zone.appendChild(chip); chip.classList.remove('wrong'); chip.classList.add('correct'); chip.classList.remove('selected'); }
    });
    timerStop(1);
}

function resetMon() { selectedMonChip = null; initMon(); }

/* ========== GENERIC LÜCKENTEXT RENDERER ========== */

function renderLuecken(containerId, data, blankClass, tabN) {
    var container = document.getElementById(containerId);
    container.innerHTML = '';
    data.forEach(function(ex) {
        var card = document.createElement('div'); card.className = 'ex-card';
        var badge = document.createElement('div'); badge.className = 'ex-badge'; badge.textContent = '#' + ex.id; card.appendChild(badge);
        var sentence = document.createElement('div'); sentence.className = 'ex-sentence';
        var skipNext = false;
        ex.segments.forEach(function(seg, si) {
            if (skipNext) { skipNext = false; return; }
            if (seg.t !== undefined) {
                var nextSeg = ex.segments[si + 1];
                if (nextSeg && nextSeg.b !== undefined && !seg.t.endsWith(' ') && seg.t.length > 0) {
                    var group = document.createElement('span'); group.className = 'nowrap-group';
                    var txt = document.createElement('span'); txt.textContent = seg.t; group.appendChild(txt);
                    var inp = document.createElement('input');
                    inp.type = 'text'; inp.className = 'blank ' + blankClass + ' ' + nextSeg.s;
                    inp.dataset.answer = nextSeg.b;
                    inp.setAttribute('autocomplete','off'); inp.setAttribute('autocorrect','off');
                    inp.setAttribute('autocapitalize','off'); inp.setAttribute('spellcheck','false');
                    inp.oninput = function() { timerAutoStart(tabN); liveCheck(this); checkAllInputs('.' + blankClass, tabN); };
                    group.appendChild(inp); sentence.appendChild(group); skipNext = true;
                } else {
                    var txt2 = document.createElement('span'); txt2.textContent = seg.t; sentence.appendChild(txt2);
                }
            } else if (seg.b !== undefined) {
                var inp2 = document.createElement('input');
                inp2.type = 'text'; inp2.className = 'blank ' + blankClass + ' ' + seg.s;
                inp2.dataset.answer = seg.b;
                inp2.setAttribute('autocomplete','off'); inp2.setAttribute('autocorrect','off');
                inp2.setAttribute('autocapitalize','off'); inp2.setAttribute('spellcheck','false');
                inp2.oninput = function() { timerAutoStart(tabN); liveCheck(this); checkAllInputs('.' + blankClass, tabN); };
                sentence.appendChild(inp2);
            }
        });
        card.appendChild(sentence); container.appendChild(card);
    });
}

function showLueckenLoesung(blankClass, tabN) {
    document.querySelectorAll('.' + blankClass).forEach(function(inp) {
        var answer = inp.dataset.answer;
        var next = inp.nextElementSibling;
        if (next && next.classList.contains('correction-hint')) next.remove();
        if (inp.value.trim().toLowerCase() === answer.toLowerCase()) {
            inp.classList.remove('wrong'); inp.classList.add('correct');
        } else {
            inp.classList.add('wrong');
            var hint = document.createElement('span'); hint.className = 'correction-hint';
            hint.textContent = answer; inp.insertAdjacentElement('afterend', hint);
        }
    });
    timerStop(tabN);
}

function resetLuecken(blankClass) {
    document.querySelectorAll('.' + blankClass).forEach(function(inp) {
        inp.value = ''; inp.classList.remove('correct', 'wrong');
        var next = inp.nextElementSibling;
        if (next && next.classList.contains('correction-hint')) next.remove();
    });
}

/* ========== TAB 2: ORDNUNGSZAHLEN ========== */

function showOrdLoesung() { showLueckenLoesung('ord-blank', 2); }
function resetOrd() { resetLuecken('ord-blank'); }

/* ========== TAB 3: DATUM SCHREIBEN ========== */

function showDatumLoesung() { showLueckenLoesung('datum-blank', 3); }
function resetDatum() { resetLuecken('datum-blank'); }

/* ========== TAB 4: AM + DATUM ========== */

function showAmDatLoesung() { showLueckenLoesung('amdat-blank', 4); }
function resetAmDat() { resetLuecken('amdat-blank'); }

/* ========== TAB 5: SATZBAU ========== */

var selectedSBChip = null;

function checkSatzbauAuto(exId) {
    var ex = SATZBAU.find(function(s) { return s.id == exId; });
    if (!ex) return;
    var row = document.getElementById('sb-drop-' + exId);
    var bank = document.getElementById('sb-bank-' + exId);
    if (bank.querySelectorAll('.chip').length > 0) {
        row.querySelectorAll('.chip').forEach(function(c) { c.classList.remove('correct', 'wrong'); });
        return;
    }
    var chips = Array.from(row.querySelectorAll('.chip'));
    var userOrder = chips.map(function(c) { return c.dataset.text; });
    var isCorrect = ex.valid.some(function(v) {
        return v.length === userOrder.length && v.every(function(p, i) { return p === userOrder[i]; });
    });
    chips.forEach(function(c) { c.classList.remove('correct', 'wrong'); c.classList.add(isCorrect ? 'correct' : 'wrong'); });
    var allDone = true;
    SATZBAU.forEach(function(s) {
        var r = document.getElementById('sb-drop-' + s.id);
        var b = document.getElementById('sb-bank-' + s.id);
        if (b.querySelectorAll('.chip').length > 0) { allDone = false; return; }
        var ch = Array.from(r.querySelectorAll('.chip'));
        var uo = ch.map(function(c) { return c.dataset.text; });
        var ok = s.valid.some(function(v) { return v.length === uo.length && v.every(function(p, i) { return p === uo[i]; }); });
        if (!ok) allDone = false;
    });
    if (allDone) timerStop(5);
}

function updateCaps(exId) {
    var row = document.getElementById('sb-drop-' + exId);
    row.querySelectorAll('.chip').forEach(function(c) { c.textContent = c.dataset.text; });
    var first = row.querySelector('.chip');
    if (first && !first.classList.contains('punct')) {
        var t = first.dataset.text;
        if (t && t.length > 0) { first.textContent = t.charAt(0).toUpperCase() + t.slice(1); }
    }
}

function initSatzbau() {
    var container = document.getElementById('satzbauContainer');
    container.innerHTML = '';
    SATZBAU.forEach(function(ex) {
        var div = document.createElement('div'); div.className = 'satzbau-item';
        var lbl = document.createElement('div'); lbl.className = 'sb-label'; lbl.textContent = 'Satz ' + ex.id; div.appendChild(lbl);
        var dropRow = document.createElement('div'); dropRow.className = 'drop-row'; dropRow.id = 'sb-drop-' + ex.id; dropRow.dataset.exId = ex.id;
        dropRow.ondragover = allowDrop;
        dropRow.ondrop = function(e) {
            e.preventDefault();
            if (!draggedChip) return;
            var dot = dropRow.querySelector('.fixed-dot');
            dropRow.insertBefore(draggedChip, dot);
            draggedChip.classList.remove('selected');
            draggedChip = null;
            updateCaps(ex.id); checkSatzbauAuto(ex.id);
        };
        dropRow.addEventListener('click', function() {
            if (selectedSBChip && selectedSBChip.dataset.exId == ex.id) {
                var dot = dropRow.querySelector('.fixed-dot');
                dropRow.insertBefore(selectedSBChip, dot);
                selectedSBChip.classList.remove('selected'); selectedSBChip = null;
                updateCaps(ex.id); checkSatzbauAuto(ex.id);
            }
        });
        var bank = document.createElement('div'); bank.className = 'chip-bank'; bank.id = 'sb-bank-' + ex.id;
        bank.ondragover = allowDrop;
        bank.ondrop = function(e) {
            e.preventDefault();
            if (!draggedChip) return;
            bank.appendChild(draggedChip);
            draggedChip.classList.remove('selected');
            draggedChip = null;
            updateCaps(ex.id); checkSatzbauAuto(ex.id);
        };
        bank.addEventListener('click', function() {
            if (selectedSBChip && selectedSBChip.dataset.exId == ex.id && selectedSBChip.parentElement.classList.contains('drop-row')) {
                bank.appendChild(selectedSBChip);
                selectedSBChip.classList.remove('selected'); selectedSBChip = null;
                updateCaps(ex.id); checkSatzbauAuto(ex.id);
            }
        });
        var shuffled = ex.parts.slice().sort(function() { return Math.random() - 0.5; });
        shuffled.forEach(function(p, pi) {
            var chip = document.createElement('div'); chip.className = 'chip'; chip.textContent = p; chip.draggable = true;
            chip.dataset.text = p; chip.dataset.exId = ex.id; chip.id = 'sb-chip-' + ex.id + '-' + pi;
            if (p === ',' || p === ';' || p === ':') chip.classList.add('punct');
            chip.addEventListener('dragstart', function() {
                draggedChip = chip;
                timerAutoStart(5);
            });
            chip.addEventListener('click', function() {
                timerAutoStart(5);
                if (selectedSBChip === chip) { chip.classList.remove('selected'); selectedSBChip = null; return; }
                if (selectedSBChip) selectedSBChip.classList.remove('selected');
                selectedSBChip = chip; chip.classList.add('selected');
            });
            bank.appendChild(chip);
        });
        var point = document.createElement('span'); point.className = 'fixed-dot'; point.textContent = ex.punct || '.';
        dropRow.appendChild(point); div.appendChild(dropRow); div.appendChild(bank); container.appendChild(div);
    });
}

function showSatzbauLoesung() {
    SATZBAU.forEach(function(ex) {
        var row = document.getElementById('sb-drop-' + ex.id);
        var bank = document.getElementById('sb-bank-' + ex.id);
        var allChips = Array.from(row.querySelectorAll('.chip')).concat(Array.from(bank.querySelectorAll('.chip')));
        row.innerHTML = '';
        ex.valid[0].forEach(function(p) {
            var chip = allChips.find(function(c) { return c.dataset.text === p; });
            if (chip) { row.appendChild(chip); chip.classList.remove('wrong'); chip.classList.add('correct'); }
        });
        var point = document.createElement('span'); point.className = 'fixed-dot'; point.textContent = ex.punct || '.';
        row.appendChild(point); updateCaps(ex.id);
    });
    timerStop(5);
}

function resetSatzbau() { initSatzbau(); selectedSBChip = null; }

/* ========== TAB 6: WORTSCHATZ ========== */

function initVocab() {
    var container = document.getElementById('vocabContainer');
    container.innerHTML = '';
    var shuffled = WORTSCHATZ.slice().sort(function() { return Math.random() - 0.5; });
    shuffled.forEach(function(item) {
        var div = document.createElement('div'); div.className = 'vocab-item'; div.dataset.id = item.id;
        var en = document.createElement('span'); en.className = 'vocab-en'; en.textContent = item.en; div.appendChild(en);
        var arrow = document.createElement('span'); arrow.className = 'vocab-arrow'; arrow.textContent = '\u2192'; div.appendChild(arrow);
        var inputs = document.createElement('div'); inputs.className = 'vocab-inputs';
        function makeVInp(cls, ph, ans, field) {
            var inp = document.createElement('input'); inp.className = cls; inp.placeholder = ph;
            inp.dataset.answer = ans; inp.dataset.field = field;
            inp.setAttribute('autocomplete','off'); inp.setAttribute('autocorrect','off');
            inp.setAttribute('autocapitalize','off'); inp.setAttribute('spellcheck','false');
            inp.oninput = function() { timerAutoStart(6); liveCheck(this); checkAllInputs('#sec-6 .vocab-inputs input', 6); };
            return inp;
        }
        if (item.type === 'n') {
            inputs.appendChild(makeVInp('art', 'der/die/das', item.artikel, 'art'));
            inputs.appendChild(makeVInp('wort', 'Deutsch', item.de, 'wort'));
            inputs.appendChild(makeVInp('plural', 'Plural', item.plural, 'plural'));
        } else {
            inputs.appendChild(makeVInp('wort', 'Deutsch', item.de, 'wort'));
        }
        div.appendChild(inputs); container.appendChild(div);
    });
}

function showVocabLoesung() {
    document.querySelectorAll('#sec-6 .vocab-inputs input').forEach(function(inp) {
        var field = inp.dataset.field; var user = inp.value.trim(); var answer = inp.dataset.answer;
        if (field === 'art') { user = user.toLowerCase(); answer = answer.toLowerCase(); }
        var existing = inp.nextElementSibling; if (existing && existing.classList.contains('vocab-hint')) existing.remove();
        if (user === answer) { inp.classList.remove('wrong'); inp.classList.add('correct'); }
        else { inp.classList.add('wrong'); var hint = document.createElement('span'); hint.className = 'vocab-hint'; hint.textContent = inp.dataset.answer; inp.insertAdjacentElement('afterend', hint); }
    });
    timerStop(6);
}

function resetVocab() {
    document.querySelectorAll('#sec-6 .vocab-inputs input').forEach(function(inp) {
        inp.value = ''; inp.classList.remove('correct', 'wrong');
        var next = inp.nextElementSibling; if (next && next.classList.contains('vocab-hint')) next.remove();
    });
}

/* ========== INIT ========== */

initMon();
renderLuecken('ordContainer', ORD_LUECKEN, 'ord-blank', 2);
renderLuecken('datumContainer', DATUM_LUECKEN, 'datum-blank', 3);
renderLuecken('amDatContainer', AMDAT_LUECKEN, 'amdat-blank', 4);
initSatzbau();
initVocab();
loadBestTimes();
</script>

</body>
</html>
